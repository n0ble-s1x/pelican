# Maintainer: Krypteia <krypteia.annex447@8alias.com>
pkgname=pelican
pkgver=0.1.0
pkgrel=1
pkgdesc="Sync music to Garmin watches over MTP, Linux-first"
arch=('x86_64' 'aarch64')
url="https://github.com/n0ble-s1x/pelican"
license=('MIT' 'Apache')
depends=('ffmpeg' 'libudev.so')
makedepends=('cargo')
optdepends=('garmin-music: udev rule installs to /etc/udev/rules.d/')
source=("$pkgname-$pkgver.tar.gz::https://github.com/n0ble-s1x/pelican/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "pelican-$pkgver"
    cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
    cd "pelican-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release --all-features
}

check() {
    cd "pelican-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    cargo test --frozen --release
}

package() {
    cd "pelican-$pkgver"
    install -Dm755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
    install -Dm644 udev/99-garmin-music.rules "$pkgdir/usr/lib/udev/rules.d/99-garmin-music.rules"
    install -Dm644 packaging/desktop/pelican.desktop "$pkgdir/usr/share/applications/pelican.desktop"
    install -Dm644 LICENSE-MIT "$pkgdir/usr/share/licenses/$pkgname/LICENSE-MIT"
    install -Dm644 LICENSE-APACHE "$pkgdir/usr/share/licenses/$pkgname/LICENSE-APACHE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
